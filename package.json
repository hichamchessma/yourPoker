{
  "name": "yourpoker",
  "version": "1.0.0",
  "description": "Poker Elite Coach - Desktop App",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dev:web": "vite --config vite.renderer.config.ts",
    "build:web": "vite build --config vite.renderer.config.ts",
    "preview:web": "vite preview --config vite.renderer.config.ts",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "i18n:lint": "node scripts/i18n-lint.js",
    "bench:coach": "npx esbuild tools/coach-bench.ts --bundle --format=esm --outfile=node_modules/.cache/bench-c.mjs --log-level=error && node node_modules/.cache/bench-c.mjs",
    "bench:engine": "npx esbuild tools/engine-bench.ts --bundle --format=esm --outfile=node_modules/.cache/bench-e.mjs --log-level=error && node node_modules/.cache/bench-e.mjs",
    "bench": "npm run bench:coach && npm run bench:engine",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "check": "npm run typecheck && npm run bench"
  },
  "keywords": [
    "poker",
    "education",
    "coach"
  ],
  "author": "Hicham",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "framer-motion": "^11.3.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.yourpoker.app",
    "productName": "YourPoker",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    }
  }
}
