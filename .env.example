VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Payments (Lemon Squeezy) — leave blank in beta (Pro unlocks for free). ──
# Public checkout URLs (one per billing cycle) from your LS product variants.
VITE_LS_CHECKOUT_MONTHLY=
VITE_LS_CHECKOUT_YEARLY=

# Server-only secrets — set these in VERCEL (not VITE_ prefixed, never exposed to the client):
#   LEMONSQUEEZY_WEBHOOK_SECRET   (from the LS webhook you create)
#   SUPABASE_URL                  (same value as VITE_SUPABASE_URL)
#   SUPABASE_SERVICE_ROLE_KEY     (Supabase → Settings → API → service_role — SECRET)
